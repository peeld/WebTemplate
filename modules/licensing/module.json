{
  "name": "licensing",
  "version": "1.0.0",
  "django_app": "licensing",
  "npm_package": "@modules/licensing",
  "url_prefix": "licensing",
  "requires": ["billing", "orgs"],
  "pip_packages": ["PyJWT>=2.8", "cryptography>=42"],
  "settings_defaults": {
    "LICENSE_APP_SECRET": "",
