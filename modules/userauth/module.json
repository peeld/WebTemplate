{
  "name": "userauth",
  "version": "0.1.0",
  "django_app": "userauth",
  "npm_package": "@modules/userauth",
  "url_prefix": "userauth",
  "requires": [],
  "pip_packages": [
    "djangorestframework-simplejwt>=5.3",
    "dj-rest-auth[with-social]>=6.0",
    "django-allauth[socialaccount]>=0.63",
    "requests>=2.31"
  ],
  "django_apps": [
    "django.contrib.sites",
    "allauth",
    "allauth.account",
    "allauth.socialaccount",
    "allauth.socialaccount.providers.google",
    "rest_framework.authtoken",
    "dj_rest_auth",
    "dj_rest_auth.registration",
    "rest_framework_simplejwt"
  ],
  "middleware": [
    "allauth.account.middleware.AccountMiddleware"
  ],
  "settings_defaults": {
    "FRONTEND_URL": "http://localhost:5173",
    "ACCOUNT_LOGIN_METHODS": {"username": true},
    "ACCOUNT_SIGNUP_FIELDS": ["email*", "username*", "password1*", "password2*"],
    "ACCOUNT_EMAIL_VERIFICATION": "none",
    "REST_USE_JWT": true,
    "JWT_AUTH_COOKIE": null,
    "RECAPTCHA_SITE_KEY": "",
    "RECAPTCHA_SECRET_KEY": ""
  },
  "description": "User authentication — registration, login, logout, and password management."
}
