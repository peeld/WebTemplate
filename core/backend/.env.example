# Copy this file to .env and fill in values for local development.
# Never commit .env to version control.

# Django
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — development uses SQLite (no config needed).
# Production requires these (used by core/settings/production.py):
# DB_NAME=webtemplate
# DB_USER=webtemplate
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# Stripe (billing module)
# Get these from https://dashboard.stripe.com/test/apikeys (use test keys for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from https://dashboard.stripe.com/test/webhooks after creating a local webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Redirect URLs after Stripe Checkout / Portal — must be absolute URLs in production
STRIPE_SUCCESS_URL=https://yourdomain.com/billing/success
STRIPE_CANCEL_URL=https://yourdomain.com/billing/pricing

# Sentry — production only; omit in development.
# SENTRY_DSN=https://your-key@sentry.io/your-project

# Production only — origins allowed to make cross-site API requests.
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Production log file path (defaults to /var/log/webtemplate/app.log).
# LOG_FILE=/var/log/webtemplate/app.log
